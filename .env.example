# Do not commit real tokens.
# When TINKOFF_INVEST_TOKEN is set, the server uses the real Tinkoff adapter;
# otherwise it falls back to read-only mock data.
TINKOFF_INVEST_TOKEN=
# Set to true/1 to use the Tinkoff sandbox instead of production (read-only either way).
TINKOFF_INVEST_SANDBOX=
# SQLite database for persisted profile, selected accounts, snapshots, reports, recommendations.
INVESTOR_MCP_STORAGE_PATH=./data/investor_mcp.db

